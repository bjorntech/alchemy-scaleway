# Required for Containers, Container Registry, and Secret Manager.
SCW_SECRET_KEY=your-scaleway-secret-key

# Required only for Object Storage buckets.
SCW_ACCESS_KEY=your-scaleway-access-key

# Required for project-scoped resources unless set per resource.
SCW_DEFAULT_PROJECT_ID=your-scaleway-project-id

# Optional. Defaults to fr-par.
SCW_DEFAULT_REGION=fr-par

# Optional. Set to 1 only when live smoke should cover Secret Manager.
SCW_SMOKE_SECRETS=0

# Optional. Defaults to https://api.scaleway.com.
SCW_API_URL=https://api.scaleway.com
