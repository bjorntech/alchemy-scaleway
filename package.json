{
  "name": "@bjorntech/alchemy-scaleway",
  "version": "0.7.0-beta.51",
  "description": "Scaleway providers for Alchemy v2",
  "keywords": [
    "alchemy",
    "alchemy-effect",
    "effect",
    "iac",
    "infrastructure-as-code",
    "scaleway",
    "typescript"
  ],
  "homepage": "https://github.com/bjorntech/alchemy-scaleway#readme",
  "bugs": {
    "url": "https://github.com/bjorntech/alchemy-scaleway/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjorntech/alchemy-scaleway.git"
  },
  "files": [
    "src",
    "README.md",
    "env.example",
    "ARCHITECTURE.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "coverage": "bun test --coverage --coverage-reporter=lcov",
    "crap": "bun run scripts/crap-index.ts --max=6",
    "smoke:scaleway": "bun run scripts/scaleway-production-smoke.ts",
    "smoke:scaleway:dns": "bun run scripts/scaleway-dns-smoke.ts",
    "smoke:scaleway:registry-copy": "bun run scripts/scaleway-registry-copy-smoke.ts",
    "smoke:scaleway:negative": "bun run scripts/scaleway-negative-flexible-ip-smoke.ts",
    "test": "bun test",
    "format": "oxfmt .",
    "prepublishOnly": "bun run check && bun test && bun run coverage && bun run crap"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@effect/platform-bun": "4.0.0-beta.74",
    "@effect/platform-node": "4.0.0-beta.74",
    "@types/bun": "latest",
    "alchemy": "2.0.0-beta.51",
    "effect": "4.0.0-beta.74",
    "oxfmt": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "alchemy": "2.0.0-beta.51",
    "effect": "4.0.0-beta.74"
  },
  "overrides": {
    "@effect/platform-node-shared": "4.0.0-beta.74"
  }
}
